<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_bao_gia_tree" model="ir.ui.view">
            <field name="name">bao_gia.tree</field>
            <field name="model">bao_gia</field>
            <field name="arch" type="xml">
                <tree string="Danh sách Báo giá" decoration-info="trang_thai == 'du_thao'" decoration-success="trang_thai == 'chap_nhan'" decoration-danger="trang_thai == 'tu_choi'">
                    <field name="so_bao_gia"/>
                    <field name="khach_hang_id"/>
                    <field name="nhan_vien_id"/>
                    <field name="ngay_lap"/>
                    <field name="tong_tien" sum="Tổng giá trị báo giá"/>
                    <field name="trang_thai" widget="badge" 
                           decoration-info="trang_thai == 'da_gui'" 
                           decoration-success="trang_thai == 'chap_nhan'" 
                           decoration-danger="trang_thai == 'tu_choi'"/>
                </tree>
            </field>
        </record>

        <record id="view_bao_gia_form" model="ir.ui.view">
            <field name="name">bao_gia.form</field>
            <field name="model">bao_gia</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <field name="trang_thai" widget="statusbar" clickable="1" statusbar_visible="du_thao,da_gui,chap_nhan"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1><field name="so_bao_gia"/></h1>
                        </div>
                        <group>
                            <group string="Thông tin chung">
                                <field name="khach_hang_id" options="{'no_create': True}"/>
                                <field name="nhan_vien_id" options="{'no_create': True}"/>
                                <field name="tong_tien" widget="monetary" options="{'currency_field': 'currency_id'}"/>
                            </group>
                            <group string="Thời gian &amp; Hiệu lực">
                                <field name="ngay_lap"/>
                                <field name="ngay_het_han"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Điều khoản &amp; Ghi chú">
                                <field name="ghi_chu" placeholder="Nhập các điều khoản ưu đãi, ghi chú thanh toán..."/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="action_bao_gia" model="ir.actions.act_window">
            <field name="name">Báo giá</field>
            <field name="res_model">bao_gia</field>
            <field name="view_mode">tree,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Chưa có báo giá nào được tạo. Bấm "Tạo mới" để bắt đầu.
                </p>
            </field>
        </record>
    </data>
</odoo>